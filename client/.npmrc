### Security Configuration

# Disable lifecycle scripts (no preinstall/postinstall/prepare scripts)
ignore-scripts=true

# Prevent automatic changes to the lockfile
package-lock=true

# Strictly use the existing lockfile (do not update it)
save=false

# Disable automatic package-lock updates
update-notifier=false

# Show warnings if peer dependencies are missing or overwritten
strict-peer-deps=true
